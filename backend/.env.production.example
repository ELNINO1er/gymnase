# Server
PORT=3001
NODE_ENV=production

# Database MySQL (production)
DB_HOST=your-mysql-host.com
DB_PORT=3306
DB_USER=gym_user
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_NAME=gym_app

# JWT (generer une cle aleatoire : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# CORS (URL du frontend deploye)
FRONTEND_URL=https://elitegym.votre-domaine.com
